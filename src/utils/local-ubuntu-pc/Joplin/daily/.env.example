# copy to $HOME/.env.joplin_daily
JOPLIN_BASE_URL=http://192.168.1.235:41184
JOPLIN_TOKEN=...
JOPLIN_NOTEBOOK=Areas/Journal/
NOTE_TITLE_FMT=%-d %b, %Y
NOTE_TIME_WINDOW=day
STATE_PATH=/state/state.json

TRELLO_KEY=your_trello_key
TRELLO_TOKEN=your_trello_token
TRELLO_BOARD_ID=...
TRELLO_TODO_LIST_NAME=Today

GOOGLE_CALENDAR_ID=primary
# When using a service account, share the target calendar with the service account
# email and prefer that calendar's real ID/email over `primary`.
GOOGLE_SERVICE_ACCOUNT_FILE=/secrets/gcal.json
# This is set automatically by the wrapper if google_service_account.json exists:
# GOOGLE_SERVICE_ACCOUNT_FILE=/run/secrets/google_service_account.json

HA_BASE_URL=http://home.assistant:8123
HA_TOKEN=your_home_assistant_long_lived_token
HA_ENTITIES=sensor.outdoor_temperature,sensor.living_room_humidity

TIMEZONE=America/Chicago

HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=...
HA_ENTITIES=binary_sensor.front_door,climate.downstairs
HA_INCLUDE_HISTORY=1
HA_HISTORY_MAX=80

GIT_ENABLE=1
GIT_REPOS=/home/sthinds/Coding/Projects/Personal

DOCKER_ENABLE=1

NETWORK_MAP_ENABLE=1
# Leave blank to auto-detect the primary LAN CIDR from `ip route`.
NETWORK_MAP_TARGET=
NETWORK_MAP_HOST_LIMIT=24
