{
	"openisland-hooks": {
		"command": "$HOME/Library/Application Support/OpenIsland/bin/OpenIslandHooks"
	},
	"open": {
		"command": "/usr/bin/open"
	},
	"notify": {
		"command": "/usr/bin/osascript",
		"prepend_args": [
			"-e"
		]
	},
	"shell": {
		"command": "/bin/bash",
		"prepend_args": [
			"-lc"
		]
	},
	"pbcopy": {
		"command": "/usr/bin/pbcopy"
	},
	"pbpaste": {
		"command": "/usr/bin/pbpaste"
	}
}