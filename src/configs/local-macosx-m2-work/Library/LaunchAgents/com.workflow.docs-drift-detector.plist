<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.workflow.docs-drift-detector</string>

	<key>ProgramArguments</key>
	<array>
		<string>/usr/local/bin/cron/run_once_daily.sh</string>
		<string>/bin/bash</string>
		<string>/Users/<USER>/.claude/routines/docs-drift-detector.sh</string>
	</array>

	<key>StartCalendarInterval</key>
	<dict>
		<key>Weekday</key>
		<integer>1</integer>
		<key>Hour</key>
		<integer>9</integer>
		<key>Minute</key>
		<integer>0</integer>
	</dict>

	<key>StandardOutPath</key>
	<string>/Users/<USER>/.claude/routines/logs/docs-drift.log</string>
	<key>StandardErrorPath</key>
	<string>/Users/<USER>/.claude/routines/logs/docs-drift.log</string>
</dict>
</plist>
