# Claude Code automated routines
# Jira Daily Digest - weekdays at 8am
0 8 * * 1-5 <USER> /bin/bash ~/.claude/routines/jira-daily-digest.sh >> ~/.claude/routines/logs/jira-digest.log 2>&1

# Docs Drift Detector - Monday at 9am
0 9 * * 1 <USER> /bin/bash ~/.claude/routines/docs-drift-detector.sh >> ~/.claude/routines/logs/docs-drift.log 2>&1

# Sprint Summary - Friday at 4pm
0 16 * * 5 <USER> /bin/bash ~/.claude/routines/sprint-summary.sh >> ~/.claude/routines/logs/sprint-summary.log 2>&1

# Trello Today → Daybook Sync - weekdays at 7am
# Disabled: launchd com.workflow.trello-daybook-sync handles this (avoids double-run/double Slack post)
# 0 7 * * 1-5 <USER> /bin/bash ~/.claude/routines/trello-daybook-sync.sh >> ~/.claude/routines/logs/trello-daybook-sync.log 2>&1

# Weekly Daybook Notebook - Friday at 3pm
0 15 * * 5 <USER> /bin/bash ~/.claude/routines/weekly-notebook.sh >> ~/.claude/routines/logs/weekly-notebook.log 2>&1

# Sprint Review Notebook - Friday at 4:15pm
15 16 * * 5 <USER> /bin/bash ~/.claude/routines/sprint-notebook.sh >> ~/.claude/routines/logs/sprint-notebook.log 2>&1
